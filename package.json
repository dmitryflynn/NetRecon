{
  "name": "netlogic",
  "version": "1.0.0",
  "description": "Attack Surface Mapper & Vulnerability Correlator",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder --win --mac --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.netlogic.app",
    "productName": "NetLogic",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "netlogic.py",
      "assets/**/*",
      "python_dist/**/*"
    ],
    "extraResources": [
      {
        "from": "python_dist/",
        "to": "python_dist/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetLogic",
      "license": "LICENSE",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "NetLogic-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}

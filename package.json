{
  "name": "netlogic",
  "version": "1.0.0",
  "description": "Attack Surface Mapper & Vulnerability Correlator",
  "author": "Dmitry Flynn",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --x64",
    "build:all": "electron-builder --win --mac --linux",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.netlogic.app",
    "productName": "NetLogic",
    "copyright": "Copyright © 2026 Dmitry Flynn",
    "icon": "netlogic.ico",
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "src/**/*",
      "netlogic.py",
      "netlogic.png",
      "netlogic.ico"
    ],
    "extraResources": [
      {
        "from": "python_dist/",
        "to": "python_dist/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "netlogic.ico",
      "requestedExecutionLevel": "asInvoker",
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "netlogic.ico",
      "uninstallerIcon": "netlogic.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NetLogic",
      "license": "LICENSE.txt",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "NetLogic-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  }
}
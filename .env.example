# NetLogic API — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign/verify JWTs. Must be at least 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NETLOGIC_JWT_SECRET=change-me-use-a-long-random-string-here

# Admin API key used to create org API keys via POST /auth/keys.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NETLOGIC_ADMIN_KEY=change-me-admin-key

# ── AI Layer (Phase 4) ────────────────────────────────────────────────────────

# Anthropic API key for Claude AI analysis. Required when AI features are enabled.
# Get yours at: https://console.anthropic.com/
NETLOGIC_ANTHROPIC_API_KEY=

# Claude model to use for AI analysis (default: claude-opus-4-7)
NETLOGIC_AI_MODEL=claude-opus-4-7

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated allowed CORS origins. Use * to allow all (dev only).
# Example: https://app.example.com,https://admin.example.com
NETLOGIC_CORS_ORIGINS=http://localhost:5173

# Directory where scan results are stored (default: ~/.netlogic/scans)
NETLOGIC_SCANS_DIR=

# API server host and port
NETLOGIC_HOST=0.0.0.0
NETLOGIC_PORT=8000

# Set to 1 to suppress the auto-open browser on startup (always set in Docker)
NETLOGIC_NO_BROWSER=0

# JWT token expiry in seconds (default: 3600 = 1 hour)
NETLOGIC_JWT_EXPIRY=3600
